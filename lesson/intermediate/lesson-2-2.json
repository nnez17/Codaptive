        "options": [
          "{'a': 1, 'b': 2}",
          "{'b': 2}",
          "{'a': 1}",
          "error"
        ],
        "answer": "{'b': 2}",
        "correctFeedback": "Key \"a\" dihapus dari dictionary.",
