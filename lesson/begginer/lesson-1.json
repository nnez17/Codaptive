        "instruction": "Ambil huruf pertama",
        "code": "print(\"abc\"[__])",
        "options": [
          "0",
          "1",
          "2",
          "-1"
        ],
        "answer": "0",
        "expectedOutput": "a",
        "correctFeedback": "Index pertama dimulai dari 0.",
        "wrongFeedback": "Python menggunakan index mulai dari 0."
