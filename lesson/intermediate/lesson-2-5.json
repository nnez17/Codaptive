  "title": "Slicing",
  "level": "intermediate",
  "pages": [
    {
      "type": "explanation",
      "content": "Slicing digunakan untuk mengambil sebagian data dari string atau list. Formatnya adalah [start:end], dimana start termasuk, end tidak termasuk.",
      "example": "text = \"python\"\nprint(text[0:2])  # py"
    },
    {
      "type": "quiz",
      "quizType": "mcq",
      "question": {
        "id": "q1",
        "type": "mcq",
        "question": "Apa output dari kode berikut?",
        "code": "text = \"python\"\nprint(text[0:2])",
        "options": [
          "py",
          "pt",
          "tho",
          "error"
        ],
        "answer": "py",
        "correctFeedback": "Index 0 sampai sebelum 2 menghasilkan 'py'.",
        "wrongFeedback": "Index akhir tidak ikut diambil."
      }
    },
    {
      "type": "quiz",
      "quizType": "fill",
      "question": {
